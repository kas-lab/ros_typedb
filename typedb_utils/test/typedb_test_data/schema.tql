define

################
## ATTRIBUTES ##
################
attribute name, value string;
attribute full-name, value string;
attribute nickname, value string;

attribute event-date @abstract, value datetime;
attribute birth-date sub event-date;

attribute phone-number, value string;

attribute email, value string;

attribute gender, value string;

attribute height, value double;

attribute age, value integer;

attribute alive, value boolean;

attribute salary, value integer;

attribute role-name, value string;

attribute robot-type, value string;

attribute address, value string;

entity person,
  owns full-name,
  owns nickname,
  owns gender,
  owns phone-number @card(0..),
  owns height,
  owns age,
  owns alive,
  owns birth-date,
  owns email @key,
  plays employment:employee,
  plays employment:employer;

entity robot,
  owns full-name @key,
  owns height,
  owns age,
  owns alive,
  owns birth-date,
  owns robot-type;

entity company,
  owns name @key,
  owns address @card(0..),
  plays employment:employer;

relation employment,
  owns role-name,
  owns salary,
  relates employee @card(0..),
  relates employer @card(0..);
